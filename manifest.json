{
  "manifest_version": 3,
  "name": "WebToWord Copier",
  "version": "2.0",
  "description": "Select content on any webpage and copy it to Word with formatting preserved.",
  "permissions": [
    "clipboardWrite",
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content_script.js"],
      "css": ["tooltip.css"]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
